# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="PayPlus Subscriptions"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ── Tenancy ───────────────────────────────────────────────────────────────────
# Separate key from APP_KEY so per-shop credential encryption can be rotated
# independently. Generate: php artisan tenant:generate-key (or base64 32 bytes).
TENANT_CREDENTIALS_KEY=

# ── Database (Postgres) ───────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically. Fallback chain: DB_URL -> DATABASE_URL
# -> individual DB_* -> PG*.
DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=payplus_subscriptions
DB_USERNAME=postgres
DB_PASSWORD=

# ── Cache / Queue / Session (CRITICAL on Railway — never `file`) ───────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Horizon ───────────────────────────────────────────────────────────────────
HORIZON_PREFIX=payplus_subs_horizon

# ── Shopify (platform app — public App Store distribution) ─────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2025-10
SHOPIFY_APP_URL=
SHOPIFY_OAUTH_SCOPES=read_orders,write_orders,read_draft_orders,write_draft_orders,read_customers,write_customers,read_products,read_fulfillments,write_fulfillments
SHOPIFY_WEBHOOK_SECRET=

# ── PayPlus (DEFAULTS ONLY — real credentials are per-shop, ENCRYPTED IN DB) ───
# Each merchant enters their own api_key/secret/terminal in Settings -> PayPlus
# Connection. Do NOT put a real merchant's keys here.
PAYPLUS_BASE_URL_DEFAULT=https://restapi.payplus.co.il
PAYPLUS_BASE_URL_SANDBOX=https://restapidev.payplus.co.il
PAYPLUS_TIMEOUT=30

# ── Mail (per-shop SMTP overrides live in DB; this is the platform default) ────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
