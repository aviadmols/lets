# ── App ───────────────────────────────────────────────────────────────────────
# Ships as "LETS" at https://app.lets.co.il (PayPlus Subscriptions, Installments
# & Post-Purchase Upsells). Locally APP_URL is your tunnel/host; in production it
# MUST equal SHOPIFY_APP_URL (https://app.lets.co.il) so OAuth callbacks, webhooks
# and App-Proxy signatures all resolve to the same host.
APP_NAME="LETS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# ── Tenancy ───────────────────────────────────────────────────────────────────
# Separate key from APP_KEY so per-shop credential encryption can be rotated
# independently. Generate: php artisan tenant:generate-key (or base64 32 bytes).
TENANT_CREDENTIALS_KEY=

# ── Database (Postgres) ───────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically. Fallback chain: DB_URL -> DATABASE_URL
# -> individual DB_* -> PG*.
DB_CONNECTION=pgsql
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=payplus_subscriptions
DB_USERNAME=postgres
DB_PASSWORD=

# ── Cache / Queue / Session (CRITICAL on Railway — never `file`) ───────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Horizon ───────────────────────────────────────────────────────────────────
HORIZON_PREFIX=payplus_subs_horizon

# ── Shopify (platform app "LETS" — public App Store distribution) ──────────────
# The API key + secret are the ONE manual step. Paste them from the Partner
# dashboard for app id 382947852289 (org 128972608):
#   https://dev.shopify.com/dashboard/128972608/apps/382947852289/settings
# API key  -> SHOPIFY_API_KEY (also the client_id in shopify.app.toml).
# Secret   -> SHOPIFY_API_SECRET (NEVER committed; signs OAuth/webhook/App-Proxy HMAC).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Bump quarterly (Jan/Apr/Jul/Oct). ONE constant drives REST + GraphQL URLs.
# Pinned to 2026-04 (latest stable) — matches shopify.app.toml [webhooks] + the
# extensions' api_version.
SHOPIFY_API_VERSION=2026-04
# Public URL of THIS app — the platform callback host for OAuth + webhooks +
# App Proxy. Production value:
SHOPIFY_APP_URL=https://app.lets.co.il
# Every scope must map to a real call (App Store reviewers reject unused scopes).
# Keep in sync with shopify.app.toml [access_scopes]. The post-purchase + thank-you
# UI extensions need NO extra OAuth scope (they are extension surfaces, not Admin
# API calls); the child-order charge reuses the existing write_draft_orders/
# write_orders scopes already listed.
SHOPIFY_OAUTH_SCOPES=read_products,read_orders,write_orders,read_draft_orders,write_draft_orders,read_customers,read_fulfillments,write_fulfillments,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders
# App-level webhooks are signed with the app secret; if left empty, config falls
# back to SHOPIFY_API_SECRET. Empty in production => webhook routes return 503.
SHOPIFY_WEBHOOK_SECRET=
# Embedded app handle (final post-install redirect target /admin/apps/{handle}).
SHOPIFY_APP_HANDLE=lets

# ── PayPlus (DEFAULTS ONLY — real credentials are per-shop, ENCRYPTED IN DB) ───
# Each merchant enters their own api_key/secret/terminal in Settings -> PayPlus
# Connection. Do NOT put a real merchant's keys here.
PAYPLUS_BASE_URL_DEFAULT=https://restapi.payplus.co.il
PAYPLUS_BASE_URL_SANDBOX=https://restapidev.payplus.co.il
PAYPLUS_TIMEOUT=30

# ── Mail (per-shop SMTP overrides live in DB; this is the platform default) ────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
