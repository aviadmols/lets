{%- comment -%}
  LETS installments button — PASTEABLE SNIPPET (manual insertion).

  For merchants who prefer code over the theme-editor app block. Copy this file to
  your theme's `snippets/` folder as `lets-installments-button.liquid`, then add it
  to your product template (e.g. sections/main-product.liquid), right after the
  add-to-cart button:

      {% render 'lets-installments-button',
         product: product,
         variant: product.selected_or_first_available_variant,
         proxy_subpath: 'payplus',
         label: 'Pay a deposit & reserve it' %}

  It is functionally identical to the app block: it renders the button + a <dialog>
  whose <iframe> loads the deposit calculator THROUGH the App Proxy
  (/apps/{proxy_subpath}/installments/modal/...), so every request is Shopify-SIGNED
  and the shop is server-derived — the snippet never sends a trusted shop id or an
  amount. See docs/INSTALLMENTS-SNIPPET.md for full install steps.
{%- endcomment -%}

{%- liquid
  assign lets_subpath = proxy_subpath | default: 'payplus'
  assign lets_product = product | default: product
  assign lets_variant = variant | default: product.selected_or_first_available_variant
  assign lets_label = label | default: 'Pay a deposit & reserve it'
  assign lets_sublabel = sublabel | default: 'Split the rest into installments'
-%}

{%- if lets_product and lets_variant -%}
  <div
    class="lets-installments"
    data-lets-installments
    data-proxy-base="/apps/{{ lets_subpath }}/installments"
    data-product-id="{{ lets_product.id }}"
    data-variant-id="{{ lets_variant.id }}"
    data-locale="{{ request.locale.iso_code | default: 'en' }}"
    data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
  >
    <button type="button" class="lets-installments__btn" data-lets-open>
      <span class="lets-installments__label">{{ lets_label }}</span>
      {%- if lets_sublabel != blank -%}
        <span class="lets-installments__sub">{{ lets_sublabel }}</span>
      {%- endif -%}
    </button>

    <dialog class="lets-installments__dialog" data-lets-dialog aria-label="{{ lets_label | escape }}">
      <button type="button" class="lets-installments__close" data-lets-close aria-label="Close">&times;</button>
      <iframe class="lets-installments__frame" data-lets-frame title="{{ lets_label | escape }}" loading="lazy" referrerpolicy="no-referrer"></iframe>
    </dialog>
  </div>

  {%- style -%}
    .lets-installments { margin: 12px 0; }
    .lets-installments__btn {
      display: inline-flex; flex-direction: column; align-items: flex-start; gap: 2px;
      width: 100%; cursor: pointer; padding: 12px 16px; border-radius: 10px;
      border: 1px solid #111827; background: #111827; color: #ffffff;
      font-size: 15px; font-weight: 600; line-height: 1.3;
    }
    .lets-installments__sub { font-size: 12px; font-weight: 400; opacity: .85; }
    .lets-installments__dialog {
      width: min(520px, 94vw); max-width: 94vw; height: min(620px, 90vh);
      padding: 0; border: none; border-radius: 14px; overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }
    .lets-installments__dialog::backdrop { background: rgba(0,0,0,.45); }
    .lets-installments__frame { width: 100%; height: 100%; border: 0; display: block; }
    .lets-installments__close {
      position: absolute; inset-inline-end: 10px; inset-block-start: 8px; z-index: 2;
      width: 32px; height: 32px; border-radius: 50%; border: none; cursor: pointer;
      background: rgba(0,0,0,.06); color: #111; font-size: 20px; line-height: 1;
    }
  {%- endstyle -%}

  <script>
    (function () {
      'use strict';
      var roots = document.querySelectorAll('[data-lets-installments]');
      var root = roots[roots.length - 1]; // bind the instance just rendered
      if (!root || root.dataset.letsBound) { return; }
      root.dataset.letsBound = '1';

      var dialog = root.querySelector('[data-lets-dialog]');
      var frame = root.querySelector('[data-lets-frame]');
      var proxyBase = root.getAttribute('data-proxy-base');
      var productId = root.getAttribute('data-product-id');

      function frameSrc(variantId) {
        // Bare numeric ids in the path (no slashes); the backend rebuilds the GID.
        var qs = '?currency=' + encodeURIComponent(root.getAttribute('data-currency') || '')
               + '&locale=' + encodeURIComponent(root.getAttribute('data-locale') || 'en');
        return proxyBase + '/modal/' + encodeURIComponent(productId) + '/' + encodeURIComponent(variantId) + qs;
      }
      function currentVariantId() {
        var url = new URL(window.location.href);
        var v = url.searchParams.get('variant');
        return v || root.getAttribute('data-variant-id');
      }
      function openDialog() {
        frame.src = frameSrc(currentVariantId());
        if (typeof dialog.showModal === 'function') { dialog.showModal(); } else { dialog.setAttribute('open', ''); }
      }
      function closeDialog() {
        if (typeof dialog.close === 'function') { dialog.close(); } else { dialog.removeAttribute('open'); }
        frame.src = 'about:blank';
      }

      root.querySelector('[data-lets-open]').addEventListener('click', openDialog);
      root.querySelector('[data-lets-close]').addEventListener('click', closeDialog);
      dialog.addEventListener('click', function (e) { if (e.target === dialog) { closeDialog(); } });

      document.addEventListener('change', function (e) {
        var input = e.target.closest('select[name="id"], input[name="id"]');
        if (input && input.value) { root.setAttribute('data-variant-id', input.value); }
      });
      document.addEventListener('variant:change', function (e) {
        var variant = e && e.detail && e.detail.variant;
        if (variant && variant.id) { root.setAttribute('data-variant-id', variant.id); }
      });

      window.addEventListener('message', function (e) {
        var data = e.data || {};
        if (!data || data.source !== 'lets') { return; }
        if (data.type === 'lets:redirect' && data.url) { window.top.location.href = data.url; }
        else if (data.type === 'lets:close') { closeDialog(); }
      });
    })();
  </script>
{%- endif -%}
