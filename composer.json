{
    "name": "aviad/payplus-subscriptions",
    "type": "project",
    "description": "PayPlus Subscriptions, Installments & Post-Purchase Upsells for Shopify \u2014 multi-tenant SaaS.",
    "keywords": [
        "shopify",
        "payplus",
        "subscriptions",
        "installments",
        "saas",
        "laravel",
        "filament"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "bezhansalleh/filament-language-switch": "^3.1",
        "filament/filament": "^3.2",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.0",
        "laravel/tinker": "^2.9",
        "predis/predis": "^2.2",
        "spatie/laravel-settings": "^3.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "block-insecure": false,
            "ignore": {
                "PKSA-mdq4-51ck-6kdq": "Dev scaffold only \u2014 Laravel 11.x line flagged by Composer 2.9 audit.",
                "PKSA-w941-zhwq-2wbm": "Dev scaffold only \u2014 filament/tables flagged by Composer 2.9 audit. saas-multitenancy-billing / security review must pin patched releases before production."
            }
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
